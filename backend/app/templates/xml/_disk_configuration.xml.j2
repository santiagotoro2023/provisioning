{% set extra_volumes = disk_layout.layout_json.extra_volumes or [] %}
{% set os_volume = disk_layout.layout_json.os_volume %}
{% set recovery_size_mb = disk_layout.layout_json.recovery_size_mb %}
{% set os_partition_number = 4 if recovery_size_mb else 3 %}
<Disk wcm:action="add">
    <DiskID>0</DiskID>
    <WillWipeDisk>true</WillWipeDisk>
    <CreatePartitions>
        <CreatePartition wcm:action="add">
            <Order>1</Order>
            <Type>EFI</Type>
            <Size>{{ disk_layout.layout_json.efi_size_mb }}</Size>
        </CreatePartition>
        <CreatePartition wcm:action="add">
            <Order>2</Order>
            <Type>MSR</Type>
            <Size>{{ disk_layout.layout_json.msr_size_mb }}</Size>
        </CreatePartition>
{% if recovery_size_mb %}
        <CreatePartition wcm:action="add">
            <Order>3</Order>
            <Type>Primary</Type>
            <Size>{{ recovery_size_mb }}</Size>
        </CreatePartition>
{% endif %}
        <CreatePartition wcm:action="add">
            <Order>{{ os_partition_number }}</Order>
            <Type>Primary</Type>
{% if os_volume == "remaining" %}
            <Extend>true</Extend>
{% else %}
            <Size>{{ os_volume.size_mb }}</Size>
{% endif %}
        </CreatePartition>
{% for volume in extra_volumes %}
        <CreatePartition wcm:action="add">
            <Order>{{ os_partition_number + loop.index }}</Order>
            <Type>Primary</Type>
            <Size>{{ volume.size_mb }}</Size>
        </CreatePartition>
{% endfor %}
    </CreatePartitions>
    <ModifyPartitions>
        <ModifyPartition wcm:action="add">
            <Order>1</Order>
            <PartitionID>1</PartitionID>
            <Format>FAT32</Format>
            <Label>System</Label>
        </ModifyPartition>
        <ModifyPartition wcm:action="add">
            <Order>2</Order>
            <PartitionID>2</PartitionID>
        </ModifyPartition>
{# Partition 3 (recovery, when recovery_size_mb is set) is deliberately left
   raw here - no Format/Label/TypeID. Formatting/typing it as WinRE during
   Setup's own DiskConfiguration pass, before Windows exists on the disk, is
   untested territory the source blog never exercises either - its
   equivalent partition stays raw through the whole install and is only
   formatted/typed afterward, manually. A real deployment failed Setup's own
   BCD creation on this exact layout with no other explanation found after a
   full git-history audit, so this was reverted to match the blog's proven
   order of operations rather than kept as an unverified assumption. The
   post-install "Recovery partition relocation" script in setup.py's
   DEFAULT_DISK_LAYOUT_POST_INSTALL_SCRIPTS formats and retypes it after
   Windows is fully installed instead. #}
        <ModifyPartition wcm:action="add">
            <Order>{{ os_partition_number }}</Order>
            <PartitionID>{{ os_partition_number }}</PartitionID>
            <Format>NTFS</Format>
            <Label>Windows</Label>
            <Letter>C</Letter>
        </ModifyPartition>
{% for volume in extra_volumes %}
        <ModifyPartition wcm:action="add">
            <Order>{{ os_partition_number + loop.index }}</Order>
            <PartitionID>{{ os_partition_number + loop.index }}</PartitionID>
            <Format>NTFS</Format>
            <Label>{{ volume.label }}</Label>
            <Letter>{{ volume.drive_letter }}</Letter>
        </ModifyPartition>
{% endfor %}
    </ModifyPartitions>
</Disk>
